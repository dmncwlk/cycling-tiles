{
  "version": 8,
  "name": "Cycling Network Overlay",
  "sources": {
    "cycling": {
      "type": "vector",
      "url": "https://dominiks-macbook-pro.tail761943.ts.net/data/v3.json"
    }
  },
  "layers": [
    {
      "id": "roads-red-minor-service-tertiary",
      "type": "line",
      "source": "cycling",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["!in", "brunnel", "bridge", "tunnel"],
        ["!=", "ramp", 1],
        ["in", "class", "minor", "service", "tertiary"]
      ],
      "paint": {
        "line-color": "#c30010",
        "line-width": {
          "base": 1.2,
          "stops": [[12, 1.3], [13, 1.6], [14, 2], [15, 2.6], [16, 3.2], [18, 4.8]]
        },
        "line-opacity": 0.85
      }
    },
    {
      "id": "cycleways-purple",
      "type": "line",
      "source": "cycling",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["!in", "brunnel", "bridge", "tunnel"],
        ["==", "class", "path"],
        ["any", ["==", "subclass", "cycleway"], ["==", "bicycle", "designated"]]
      ],
      "paint": {
        "line-color": "#7b3294",
        "line-width": {
          "base": 1.2,
          "stops": [[12, 1.3], [13, 1.6], [14, 2], [15, 2.6], [16, 3.2], [18, 4.8]]
        },
        "line-opacity": 0.95
      }
    },
    {
      "id": "tracks-orange-continuous",
      "type": "line",
      "source": "cycling",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["!in", "brunnel", "bridge", "tunnel"],
        ["==", "class", "track"]
      ],
      "paint": {
        "line-color": "#e85d04",
        "line-width": {
          "base": 1.2,
          "stops": [[12, 1.3], [13, 1.6], [14, 2], [15, 2.6], [16, 3.2], [18, 4.8]]
        },
        "line-opacity": 0.9
      }
    },
    {
      "id": "footway-paths-grey-dashed",
      "type": "line",
      "source": "cycling",
      "source-layer": "transportation",
      "minzoom": 14,
  "layout": {
    "line-join": "round",
    "visibility": "visible"
  },
  "paint": {
    "line-color": "grey",
    "line-dasharray": [2, 1],
    "line-width": {
      "base": 1.2,
      "stops": [
        [13, 0.6],
        [14, 1],
        [15, 1.3],
        [17, 1.3],
        [18, 1.6]
      ]
    }
  },
  "metadata": {},
  "filter": [
    "all",
    ["==", "$type", "LineString"],
    [
      "!in",
      "brunnel",
      "bridge",
      "tunnel"
    ],
    ["in", "class", "path"],
    [
      "in",
      "subclass",
      "footway",
      "path"
    ],
    ["!=", "bicycle", "designated"],
    ["!=", "horse", "designated"]
  ]
}
  ]
}
